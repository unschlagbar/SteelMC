{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SteelConfig",
  "description": "Configuration schema for Steel Minecraft server",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "description": "Server configuration",
      "properties": {
        "server_port": {
          "type": "integer",
          "description": "Server port",
          "minimum": 1,
          "maximum": 65000,
          "default": 25565
        },
        "max_players": {
          "type": "integer",
          "description": "Maximum number of players allowed on the server",
          "minimum": 1,
          "maximum": 2147483647,
          "default": 20
        },
        "allow_extended_view_distance": {
          "type": "boolean",
          "description": "Allow view_distance above vanilla's 32-chunk cap, up to Steel's 127-chunk cap",
          "default": false
        },
        "view_distance": {
          "type": "integer",
          "description": "Maximum view distance in chunks. Normally 1-32; 1-127 when allow_extended_view_distance is true.",
          "minimum": 1,
          "maximum": 127,
          "default": 10
        },
        "simulation_distance": {
          "type": "integer",
          "description": "Maximum simulation distance in chunks",
          "minimum": 1,
          "maximum": 127,
          "default": 10
        },
        "online_mode": {
          "type": "boolean",
          "description": "Whether to use Mojang's authentication service",
          "default": true
        },
        "auth_server": {
          "type": "string",
          "description": "Optional authentication endpoint for online-mode hasJoined checks. Omit to use Mojang's session server.",
          "format": "uri"
        },
        "encryption": {
          "type": "boolean",
          "description": "Whether to enable encryption for client-server communication",
          "default": true
        },
        "allow_flight": {
          "type": "boolean",
          "description": "Whether the server allows unauthorised client flight",
          "default": false
        },
        "motd": {
          "type": "string",
          "description": "Message of the day displayed in server lists",
          "default": "A Steel Server"
        },
        "use_favicon": {
          "type": "boolean",
          "description": "Whether to use a custom favicon for the server",
          "default": true
        },
        "favicon": {
          "type": "string",
          "description": "Path to the favicon file (PNG format, 64x64 pixels)",
          "default": "config/favicon.png"
        },
        "enforce_secure_chat": {
          "type": "boolean",
          "description": "Whether to enforce secure chat",
          "default": false
        },
        "chat_spam_threshold_seconds": {
          "type": "integer",
          "description": "Vanilla chat spam threshold window in seconds; values <= 0 disable throttling",
          "minimum": -2147483648,
          "maximum": 2147483647,
          "default": 10
        },
        "command_spam_threshold_seconds": {
          "type": "integer",
          "description": "Vanilla command spam threshold window in seconds; values <= 0 disable throttling",
          "minimum": -2147483648,
          "maximum": 2147483647,
          "default": 10
        },
        "compression": {
          "type": "object",
          "description": "Compression settings",
          "properties": {
            "threshold": {
              "type": "integer",
              "description": "Compression threshold in bytes",
              "minimum": 256,
              "maximum": 2147483647,
              "default": 256
            },
            "level": {
              "type": "integer",
              "description": "Compression level (1 = fastest, 9 = best compression)",
              "minimum": 1,
              "maximum": 9,
              "default": 4
            }
          },
          "required": ["threshold", "level"],
          "additionalProperties": false
        },
        "server_links": {
          "type": "object",
          "description": "Server links configuration",
          "properties": {
            "enable": {
              "type": "boolean",
              "description": "Enable the server links feature",
              "default": false
            },
            "links": {
              "type": "array",
              "description": "List of server links to display in the server menu",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "description": "Label for the link - either a built-in type (string) or custom TextComponent (object)",
                    "oneOf": [
                      {
                        "type": "string",
                        "enum": [
                          "bug_report",
                          "community_guidelines",
                          "support",
                          "status",
                          "feedback",
                          "community",
                          "website",
                          "forums",
                          "news",
                          "announcements"
                        ],
                        "description": "Built-in server link type"
                      },
                      {
                        "type": "object",
                        "description": "Custom text component with formatting",
                        "properties": {
                          "text": {
                            "type": "string",
                            "description": "The text content"
                          },
                          "color": {
                            "type": "string",
                            "description": "Text color (named color or #RRGGBB hex)",
                            "pattern": "^(#[0-9a-fA-F]{6}|black|dark_blue|dark_green|dark_aqua|dark_red|dark_purple|gold|gray|dark_gray|blue|green|aqua|red|light_purple|yellow|white|reset)$"
                          },
                          "bold": {
                            "type": "boolean",
                            "description": "Make text bold"
                          },
                          "italic": {
                            "type": "boolean",
                            "description": "Make text italic"
                          },
                          "underlined": {
                            "type": "boolean",
                            "description": "Underline text"
                          },
                          "strikethrough": {
                            "type": "boolean",
                            "description": "Strikethrough text"
                          },
                          "obfuscated": {
                            "type": "boolean",
                            "description": "Obfuscate text"
                          }
                        },
                        "required": ["text"],
                        "additionalProperties": true
                      }
                    ]
                  },
                  "url": {
                    "type": "string",
                    "description": "The URL for this link",
                    "format": "uri"
                  }
                },
                "required": ["label", "url"],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "additionalProperties": false
        },
        "threads": {
          "type": "object",
          "description": "Optional worker counts for server thread pools. 0 or omitted uses each pool's automatic default.",
          "properties": {
            "main_runtime": {
              "type": "integer",
              "description": "Worker threads for the primary Tokio runtime",
              "minimum": 0,
              "default": 0
            },
            "chunk_runtime": {
              "type": "integer",
              "description": "Worker threads for the chunk Tokio runtime",
              "minimum": 0,
              "default": 0
            },
            "chunk_generation": {
              "type": "integer",
              "description": "Worker threads for the Rayon chunk generation pool",
              "minimum": 0,
              "default": 0
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "server_port",
        "max_players",
        "view_distance",
        "simulation_distance",
        "online_mode",
        "encryption",
        "motd",
        "use_favicon",
        "favicon"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "allow_extended_view_distance": {
                "const": true
              }
            },
            "required": ["allow_extended_view_distance"]
          },
          "then": {
            "properties": {
              "view_distance": {
                "maximum": 127
              }
            }
          },
          "else": {
            "properties": {
              "view_distance": {
                "maximum": 32
              }
            }
          }
        }
      ]
    },
    "log": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "log_path": {
          "type": "string",
          "description": "Path where store the log files and history",
          "default": "./.logs"
        },
        "log_level": {
          "type": "string",
          "description": "The level of information the logger will show",
          "enum": ["error", "warn", "info", "debug", "trace"],
          "default": "info"
        },
        "time": {
          "type": "string",
          "description": "Time format: none, date (HH:MM:SS:mmm), or uptime (seconds since start)",
          "enum": ["none", "date", "uptime"],
          "default": "uptime"
        },
        "module_path": {
          "type": "boolean",
          "description": "Whether the module_path of the log should be displayed",
          "default": false
        },
        "extra": {
          "type": "boolean",
          "description": "Whether the extra data of the log should be displayed",
          "default": false
        },
        "log_file": {
          "type": "boolean",
          "description": "Whether the log should be written into a file",
          "default": true
        },
        "rotation_time": {
          "type": "string",
          "description": "Time between log file rotations",
          "enum": ["none", "hourly", "daily", "weekly", "monthly"],
          "default": "daily"
        },
        "max_history": {
          "type": "integer",
          "description": "Amount of console commands saved",
          "default": 50,
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["server"],
  "additionalProperties": false
}
